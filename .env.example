# Shared
DOCKER_IMAGE_NAME=your-docker-image
VITE_API_BASE_URL=http://your-api-host:4002

# Development
VITE_SITE_PORT=3005
VITE_SITE_HMR_PORT=3005
VITE_SITE_ORIGIN=http://localhost:3005
VITE_SITE_ALLOWED_ORIGINS=http://localhost:3005,http://127.0.0.1:3005,http://your-dev-ip:3005

VITE_ADMIN_PORT=3006
VITE_ADMIN_HMR_PORT=3006
VITE_ADMIN_ORIGIN=http://admin.localhost:3006
VITE_ADMIN_ALLOWED_ORIGINS=http://admin.localhost:3006,http://your-dev-ip:3006

# Production
NGINX_PROFILE=demo
DOMAIN=your-site-domain.example
ADMIN_HOST=admin.your-site-domain.example
